# Nginx Proxy Manager API
NPM_BASE_URL=https://npm.example.com

# Prefer token auth when available
NPM_TOKEN=

# Or use identity + secret
NPM_IDENTITY=admin@example.com
NPM_SECRET=replace-me

NPM_VERIFY_SSL=true

# Defaults used when hosts omit values
DEFAULT_SCHEME=http
DEFAULT_ACCESS_LIST=lan
DEFAULT_CERT_STRATEGY=wildcard
DEFAULT_CERT_NAME=*.example.com
DEFAULT_BLOCK_COMMON_EXPLOITS=true
DEFAULT_WEBSOCKET_SUPPORT=true
DEFAULT_CACHING_ENABLED=false
DEFAULT_HTTP2_SUPPORT=true
DEFAULT_HSTS_ENABLED=false
DEFAULT_FORCE_SSL=true

# Runtime behavior
DRY_RUN=true
LOG_LEVEL=INFO
