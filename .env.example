# Nginx Proxy Manager API
NPM_BASE_URL=https://npm.example.com

# Prefer token auth when available
NPM_TOKEN=

# Or use identity + secret
NPM_IDENTITY=admin@example.com
NPM_SECRET=replace-me

NPM_VERIFY_SSL=true

# Defaults used when hosts omit values
DEFAULT_SCHEME=http
DEFAULT_ACCESS_LIST=lan
DEFAULT_CERT_STRATEGY=wildcard
DEFAULT_CERT_NAME=*.example.com
DEFAULT_BLOCK_COMMON_EXPLOITS=true
DEFAULT_WEBSOCKET_SUPPORT=true
DEFAULT_CACHING_ENABLED=false
DEFAULT_HTTP2_SUPPORT=true
DEFAULT_HSTS_ENABLED=false
DEFAULT_FORCE_SSL=true

# Runtime behavior
DRY_RUN=true
LOG_LEVEL=INFO

# UI
UI_USERS=admin:change-me
UI_BIND=0.0.0.0
UI_PORT=8080
HISTORY_PATH=/app/data/history.json
HISTORY_MAX=200

# Deletion safety
DELETE_ENABLED=false
ALLOW_EMPTY_SOURCE=false
MAX_DELETE_COUNT=0
MAX_DELETE_PERCENT=0
FORCE_DELETE=false

# Let's Encrypt DNS challenge (optional)
CERT_EMAIL=you@example.com
CERT_AGREE_TOS=true
CERT_DNS_CHALLENGE=true
CERT_DNS_PROVIDER=cloudflare
CERT_DNS_PROVIDER_CREDENTIALS=dns_cloudflare_api_token=replace-me
